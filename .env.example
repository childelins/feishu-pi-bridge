FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Pi 默认 provider / model（留空则用 Pi settings.json 的 defaultProvider / defaultModel）
# PI_PROVIDER=NewAPI
# PI_MODEL=glm-4.6

# /model <编号> 快捷切换映射（可选）
# 格式：逗号分隔的 n=modelId，n 必须 >= 1（0 保留给"恢复默认"）
# 跨 provider 时必须用 provider/modelId 形式（与 Pi --model 语法一致）
# 同 provider 可省略前缀，会自动套用上面的 PI_PROVIDER
# FEISHU_MODEL_MAP="1=NewAPI/glm-5.2,2=Tencent/deepseek-v4-flash-202605,3=Tencent/deepseek-v4-pro-202606"

# Pi 工作目录（可选）。设置后所有 Pi 子进程的 shell 命令、文件操作都在此目录下执行。
# 不设置则继承 bridge 进程的 cwd（通常是 start 命令执行目录）。
# 支持相对路径（相对于 bridge 进程 cwd）和绝对路径。
# FEISHU_BRIDGE_WORKDIR=/home/childelins/code/projects/my-project

# RPC prompt 超时（毫秒，默认 300000=5 分钟）。Pi 调用耗时 skill（teach、搜索等）
# 时可能需较长时间，若仍超时可调高。日报走独立 10 分钟超时。
# FEISHU_BRIDGE_RPC_TIMEOUT_MS=300000

# 每天 8:00 / 20:00 由 crontab 触发 pnpm run daily-report；飞书发"日报"也可手动触发
FEISHU_DAILY_REPORT_CHAT_ID=
