{
  "name": "feishu-pi-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Feishu long-connection bridge to pi-coding-agent RPC, with daemon lifecycle management.",
  "type": "module",
  "bin": {
    "feishu-pi-bridge": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:link": "tsc && pnpm link --global",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "start": "node dist/index.js daemon",
    "daily-report": "node dist/index.js daily-report",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.42.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.63.0"
  },
  "engines": {
    "node": ">=18.17"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["protobufjs"]
  }
}
